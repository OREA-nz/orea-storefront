{
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/cart/c/:path*",
      "destination": "https://orea-8820.myshopify.com/cart/c/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}